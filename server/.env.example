# Backend Configuration
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/kiddotrack
JWT_SECRET=your_jwt_secret_here

# Frontend URL for CORS
FRONTEND_URL=https://your-app.vercel.app

# Email Configuration (Brevo - Recommended Free API)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=your-verified-gmail@gmail.com

# Email Configuration (Manual - Legacy/Dev)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
